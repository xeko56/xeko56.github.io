<!DOCTYPE html>

<html xmlns="http://www.w3.org/1999/xhtml">

<head>
    <title>Highscoreboard</title>
</head>

<body>
    <table class="table">
        <thead>
            <tr>
                <th scope="col" style="width:50px"></th>
                <th scope="col" style="width:100px">Player Name</th>
                <th scope="col">Score</th>

            </tr>
        </thead>
        <tbody>
            <% if(data.length){
                for(var i = 0; i < data.length; i++) {%>
                <tr>
                    <th scope="row">
                        <%= (i+1) %>
                    </th>
                    <td>
                        <%= data[i].playerName%>
                    </td>
                    <td>
                        <%= data[i].score%>
                    </td>
                </tr>
                <% }
}else{ %>
                    <tr>
                        <td colspan="3">No Data Availed</td>
                    </tr>
                    <% } %>
        </tbody>
    </table>
</body>

</html>